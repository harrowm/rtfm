# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Redis connection
REDIS_URL=redis://localhost:6379

# Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Model configuration
LLM_MODEL=qwen:14b
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Semantic cache
CACHE_DISTANCE_THRESHOLD=0.15
CACHE_TTL_SECONDS=86400

# Session memory
SESSION_TTL_HOURS=24

# Application
LOG_LEVEL=info
APP_HOST=127.0.0.1
APP_PORT=8000
