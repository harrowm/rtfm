# Copy this file to .env and adjust values as needed
# cp .env.example .env

# Redis connection
REDIS_URL=redis://localhost:6379

# Ollama endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Model configuration
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMS=1024

# Chunking
# Smaller chunks = less context sent to LLM per query = faster TTFT
CHUNK_SIZE=300
CHUNK_OVERLAP=30

# Semantic cache
# Cosine distance below which a cached answer is returned.
# 0.25 catches rewording of the same question (bge-m3 recommended range: 0.15-0.35)
CACHE_DISTANCE_THRESHOLD=0.25
CACHE_TTL_SECONDS=86400

# Retrieval scope gating
# Cosine distance above which the best-matching chunk is considered off-topic.
# Questions that exceed this threshold are rejected without calling the LLM.
# 0.5 = strict (safe for narrow topic docs), 0.7 = permissive (broad topic docs)
RETRIEVAL_SCORE_THRESHOLD=0.6

# Session memory
SESSION_TTL_HOURS=24

# Application
LOG_LEVEL=info
APP_HOST=127.0.0.1
APP_PORT=8000

# LLM performance tuning
# Smaller context window = less KV-cache prefill = faster time-to-first-token
# 2048 is a good balance for RAG (5 chunks x ~500 tokens fits comfortably)
LLM_NUM_CTX=2048
# Keep model loaded in GPU memory between requests (avoids cold-load penalty)
# Set to -1 to keep forever, or a duration like 24h
OLLAMA_KEEP_ALIVE=24h
# GPU layers to offload (99 = everything, recommended for Apple Silicon)
LLM_NUM_GPU=99
